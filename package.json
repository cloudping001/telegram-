{
  "name": "telegram-support-console",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "admin",
    "worker"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:worker dev:admin",
    "dev:admin": "npm --workspace admin run dev",
    "dev:worker": "npm --workspace worker run dev",
    "build": "npm-run-all build:worker build:admin",
    "build:admin": "npm --workspace admin run build",
    "build:worker": "npm --workspace worker run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
